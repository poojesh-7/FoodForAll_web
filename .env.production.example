APP_ENV=production
NODE_ENV=production
PORT=5000
ENV_RESOURCE_PREFIX=prod-food-rescue
# 
# Same-origin API URL keeps auth cookies first-party. With the bundled Nginx
# deployment, Nginx serves /api/v1 from the backend. With split hosting, set
# API_PROXY_TARGET to the backend origin so Next.js rewrites /api/v1 there.
NEXT_PUBLIC_API_URL=/api/v1
# API_PROXY_TARGET=https://api.example.com
NEXT_PUBLIC_CASHFREE_MODE=production
FRONTEND_URL=https://app.example.com
FRONTEND_ORIGINS=https://app.example.com
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
TRUST_PROXY_HOPS=1
TRUST_MAX_GAIN_PER_DAY=10
TRUST_PROVIDER_REPEAT_DECAY=1,0.5,0
TRUST_LOW_SCORE_THRESHOLD=70
TRUST_HIGH_SCORE_THRESHOLD=95
MAX_UNPAID_HOLDS_LOW_TRUST=1
MAX_UNPAID_HOLDS_NORMAL=3
MAX_UNPAID_HOLDS_HIGH_TRUST=4
ABUSE_HOLD_LOOKBACK_HOURS=24
EXCESSIVE_HOLD_PATTERN_THRESHOLD=5
REPEATED_ABANDONMENT_THRESHOLD=3
TRUST_RAPID_GROWTH_DIAGNOSTIC_THRESHOLD=8
USER_MAX_ACTIVE_RESERVATIONS=5
USER_RL1_MAX_ACTIVE_RESERVATIONS=3
USER_RL2_MAX_ACTIVE_RESERVATIONS=2
USER_RL3_MAX_ACTIVE_RESERVATIONS=1
NGO_MAX_ACTIVE_RESERVATIONS=8
NGO_RL1_MAX_ACTIVE_RESERVATIONS=5
NGO_RL2_MAX_ACTIVE_RESERVATIONS=2
NGO_RL3_MAX_ACTIVE_RESERVATIONS=1
NGO_RL1_BULK_ENABLED=true
NGO_RL2_BULK_ENABLED=false
NGO_RL3_BULK_ENABLED=false
DEPOSIT_ENFORCEMENT_DISABLE_BULK=true
VOLUNTEER_PICKUP_TIMEOUT_MINUTES=15
VOLUNTEER_DELIVERY_TIMEOUT_MINUTES=30
FOOD_MIN_PICKUP_WINDOW_MINUTES=30
FOOD_MIN_NGO_RESCUE_REMAINING_MINUTES=30
FOOD_EXPIRY_ALERT_LEAD_MINUTES=30
SELF_PICKUP_CANCELLATION_CUTOFF_MINUTES=20
PAYMENT_HOLD_TIMEOUT_MINUTES=10
JSON_BODY_LIMIT=256kb
URLENCODED_BODY_LIMIT=64kb
METRICS_TOKEN=replace-with-prometheus-scrape-token

POSTGRES_DB=food_rescue
POSTGRES_USER=food_rescue
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://food_rescue:replace-with-strong-password@postgres:5432/food_rescue
PGSSL=false
PG_POOL_MAX=20

REDIS_URL=redis://redis:6379
QUEUE_PREFIX=prod-food-rescue
QUEUE_WORKER_CONCURRENCY=5
QUEUE_LOCK_DURATION_MS=120000
QUEUE_STALLED_INTERVAL_MS=30000
QUEUE_MAX_STALLED_COUNT=2
QUEUE_SHUTDOWN_TIMEOUT_MS=30000
API_SHUTDOWN_TIMEOUT_MS=30000
WORKER_PROCESS_SHUTDOWN_TIMEOUT_MS=45000
WORKER_HEARTBEAT_INTERVAL_MS=30000
WORKER_STALE_HEARTBEAT_MS=90000
QUEUE_DELAYED_OVERDUE_MS=120000
QUEUE_STUCK_ACTIVE_MS=900000

JWT_SECRET=replace-with-32-plus-character-random-secret
GOOGLE_CLIENT_ID=replace-with-google-web-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace-with-google-web-client-id.apps.googleusercontent.com
AUTH_ENABLE_OTP=false
# Optional future phone OTP support:
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=replace-with-twilio-secret
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

CASHFREE_ENV=production
CASHFREE_APP_ID=replace-with-production-app-id
CASHFREE_SECRET_KEY=replace-with-production-secret-key
CASHFREE_WEBHOOK_SECRET=replace-with-production-webhook-secret
# false = production website live with sandbox payments disabled before Cashfree approval.
# true = production payments enabled after Cashfree approval.
PAYMENTS_ENABLED=false
PLATFORM_COMMISSION_PERCENT=5

SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret
MAX_UPLOAD_BYTES=5242880

SOCKET_PING_INTERVAL_MS=25000
SOCKET_PING_TIMEOUT_MS=20000

BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_SECONDS=86400
BACKUP_VERIFY=true

# One-time first-admin bootstrap. Do not keep these set after use.
# BOOTSTRAP_ADMIN_PHONE=+911234567890
# BOOTSTRAP_ADMIN_CONFIRM=promote-admin
