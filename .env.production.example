APP_ENV=production
NODE_ENV=production
PORT=5000
ENV_RESOURCE_PREFIX=prod-food-rescue
# 
PUBLIC_API_URL=https://app.example.com/api/v1
NEXT_PUBLIC_CASHFREE_MODE=production
FRONTEND_URL=https://app.example.com
FRONTEND_ORIGINS=https://app.example.com
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
TRUST_PROXY_HOPS=1
JSON_BODY_LIMIT=256kb
URLENCODED_BODY_LIMIT=64kb
METRICS_TOKEN=replace-with-prometheus-scrape-token

POSTGRES_DB=food_rescue
POSTGRES_USER=food_rescue
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://food_rescue:replace-with-strong-password@postgres:5432/food_rescue
PGSSL=false
PG_POOL_MAX=20

REDIS_URL=redis://redis:6379
QUEUE_PREFIX=prod-food-rescue
QUEUE_WORKER_CONCURRENCY=5
QUEUE_LOCK_DURATION_MS=120000
QUEUE_STALLED_INTERVAL_MS=30000
QUEUE_MAX_STALLED_COUNT=2
QUEUE_SHUTDOWN_TIMEOUT_MS=30000
API_SHUTDOWN_TIMEOUT_MS=30000
WORKER_PROCESS_SHUTDOWN_TIMEOUT_MS=45000
WORKER_HEARTBEAT_INTERVAL_MS=30000
WORKER_STALE_HEARTBEAT_MS=90000
QUEUE_DELAYED_OVERDUE_MS=120000
QUEUE_STUCK_ACTIVE_MS=900000

JWT_SECRET=replace-with-32-plus-character-random-secret
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-twilio-secret
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

CASHFREE_ENV=production
CASHFREE_APP_ID=replace-with-production-app-id
CASHFREE_SECRET_KEY=replace-with-production-secret-key
CASHFREE_WEBHOOK_SECRET=replace-with-production-webhook-secret
PLATFORM_COMMISSION_PERCENT=5

SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret
MAX_UPLOAD_BYTES=5242880

SOCKET_PING_INTERVAL_MS=25000
SOCKET_PING_TIMEOUT_MS=20000

BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_SECONDS=86400
BACKUP_VERIFY=true
